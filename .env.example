# MongoDB connection URI — points to the local Docker container by default
MONGODB_URI=mongodb://localhost:27017/botfunnel

# Redis connection URL — points to the local Docker container by default
REDIS_URL=redis://localhost:6379

# Session TTL
SESSION_TTL_DEFAULT_HOURS=24
SESSION_TTL_REMEMBER_ME_DAYS=30

# Session cookie security (set true/strict in production)
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax

# Super Admin (seeded on first startup)
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=<replace-with-strong-password>

# Mail (Mailpit for local dev)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@botfunnel.local
SUPPORT_EMAIL=support@botfunnel.local

# Application base URL (used in emails)
APP_URL=http://localhost:3000

# Maximum active projects per user (hard cap, service-enforced)
PROJECTS_MAX_PER_USER=5

# Bot module
# 32 bytes / 64 hex chars; generate with `openssl rand -hex 32`. NEVER commit a real value.
BOT_TOKEN_ENCRYPTION_KEY=
# Telegram Bot API base URL (defaults to https://api.telegram.org; override for staging-against-mock).
TELEGRAM_BASE_URL=
