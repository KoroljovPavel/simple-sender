# MongoDB connection URI — points to the local Docker container by default
MONGODB_URI=mongodb://localhost:27017/botfunnel

# Redis connection URL — points to the local Docker container by default
REDIS_URL=redis://localhost:6379

# Session TTL
SESSION_TTL_DEFAULT_HOURS=24
SESSION_TTL_REMEMBER_ME_DAYS=30

# Super Admin (seeded on first startup)
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=changeme123

# Mail (Mailpit for local dev)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@botfunnel.local
SUPPORT_EMAIL=support@botfunnel.local

# Application base URL (used in emails)
APP_URL=http://localhost:3000
